<Window
    x:Class="AIWF.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AIWF 原生桌面">
    <Grid Padding="20" RowSpacing="14">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#CCF1F1F2" Offset="0" />
                <GradientStop Color="#CCE5E7EB" Offset="0.48" />
                <GradientStop Color="#CCF6F6F7" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.Resources>
            <AcrylicBrush x:Key="SurfaceAcrylicBrush" TintColor="#FFF6F6F7" TintOpacity="0.70" FallbackColor="#FFF6F6F7" />
            <AcrylicBrush x:Key="CardAcrylicBrush" TintColor="#FFFFFFFF" TintOpacity="0.56" FallbackColor="#FFFCFCFC" />
            <AcrylicBrush x:Key="PanelAcrylicBrush" TintColor="#FFF2F3F5" TintOpacity="0.64" FallbackColor="#FFF2F3F5" />
            <AcrylicBrush x:Key="HeroAcrylicBrush" TintColor="#FFFFFFFF" TintOpacity="0.60" FallbackColor="#FFF7F7F7" />
            <Style x:Key="TouchTextBoxStyle" TargetType="TextBox">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="BorderBrush" Value="#66555555" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            <Style x:Key="TouchComboBoxStyle" TargetType="ComboBox">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="#1F0F172A" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource CardAcrylicBrush}" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="12" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="HeroHeaderBorder" Grid.Row="0" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource HeroAcrylicBrush}" CornerRadius="16" Padding="16" Opacity="0">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" IsHitTestVisible="False" />
                <Border Grid.Column="0" CornerRadius="3">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFC62828" Offset="0" />
                            <GradientStop Color="#FFEF4444" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="AIWF 原生桌面" FontSize="28" FontWeight="SemiBold" Foreground="#FF111111" />
                    <TextBlock Text="Fluent 风格触控优先工作台" Opacity="0.85" Foreground="#FF374151" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="NavShellBorder" Grid.Row="1" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource SurfaceAcrylicBrush}" CornerRadius="14" Padding="8" Opacity="0">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="WorkspaceNavButton" Click="OnWorkspaceNavClick" Content="工作台" UseSystemFocusVisuals="True" MinHeight="40" Padding="16,0" MinWidth="140">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFFDECEC" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFC62828" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF111111" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFFBD5D5" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF8E1B1B" />
                        </Button.Resources>
                    </Button>
                    <Button x:Name="ResultNavButton" Click="OnResultNavClick" Content="结果" UseSystemFocusVisuals="True" MinHeight="40" Padding="16,0" MinWidth="140">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFFDECEC" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFC62828" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF111111" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFFBD5D5" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF8E1B1B" />
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="QuickHealthButton" Click="OnHealthClick" Content="健康检查" UseSystemFocusVisuals="True" MinHeight="40" Padding="16,0" MinWidth="120">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFF1F1F1" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FF6B7280" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFE5E7EB" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF4B5563" />
                        </Button.Resources>
                    </Button>
                    <Button x:Name="QuickRunButton" Click="OnRunCleaningClick" Content="运行" UseSystemFocusVisuals="True" MinHeight="40" Padding="16,0" MinWidth="120">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8E1B1B" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FF8E1B1B" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FF6E1111" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF6E1111" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF" />
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentHostGrid" Grid.Row="2" Opacity="0">
            <Grid x:Name="WorkspaceSectionGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource PanelAcrylicBrush}" CornerRadius="12" Padding="10">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FFC62828" CornerRadius="2" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="工作台" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                            <TextBlock Text="连接、参数与操作" Foreground="#FF4B5563" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto" HorizontalScrollMode="Disabled" Margin="0,10,0,0">
                    <Grid x:Name="WorkspaceCardsGrid" ColumnSpacing="14" RowSpacing="14">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition />
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="WorkspaceRow0" Height="Auto" />
                            <RowDefinition x:Name="WorkspaceRow1" Height="Auto" />
                            <RowDefinition x:Name="WorkspaceRow2" Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="WorkspaceCol0" Width="2*" />
                            <ColumnDefinition x:Name="WorkspaceCol1" Width="2*" />
                            <ColumnDefinition x:Name="WorkspaceCol2" Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ConnectionCard" Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="连接配置" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                <TextBlock Text="桥接地址" />
                                <TextBox x:Name="BridgeUrlTextBox" Style="{StaticResource TouchTextBoxStyle}" Text="http://127.0.0.1:18081" />
                                <TextBlock Text="API Key（可选）" />
                                <TextBox x:Name="ApiKeyTextBox" Style="{StaticResource TouchTextBoxStyle}" />
                                <TextBlock Text="所有者" />
                                <TextBox x:Name="OwnerTextBox" Style="{StaticResource TouchTextBoxStyle}" Text="native" />
                                <TextBlock Text="执行者" />
                                <TextBox x:Name="ActorTextBox" Style="{StaticResource TouchTextBoxStyle}" Text="native" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="ParamsCard" Grid.Column="1" Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="运行参数" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                <TextBlock Text="报告标题" />
                                <TextBox x:Name="ReportTitleTextBox" Style="{StaticResource TouchTextBoxStyle}" Text="Native WinUI Smoke Report" />
                                <TextBlock Text="输入 CSV 路径（可选）" />
                                <TextBox x:Name="InputCsvTextBox" Style="{StaticResource TouchTextBoxStyle}" />
                                <TextBlock Text="Office 主题" />
                                <ComboBox x:Name="OfficeThemeComboBox" Style="{StaticResource TouchComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="assignment" />
                                    <ComboBoxItem Content="debate_plus" />
                                    <ComboBoxItem Content="academic" />
                                    <ComboBoxItem Content="professional" />
                                </ComboBox>
                                <TextBlock Text="Office 语言" />
                                <ComboBox x:Name="OfficeLangComboBox" Style="{StaticResource TouchComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="zh" />
                                    <ComboBoxItem Content="en" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ActionsCard" Grid.Column="2" Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10" VerticalAlignment="Bottom">
                                <TextBlock Text="操作" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                <Button x:Name="HealthButton" Click="OnHealthClick" Content="健康检查" UseSystemFocusVisuals="True" MinHeight="44" MinWidth="156">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFF1F1F1" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FF6B7280" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFE5E7EB" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF4B5563" />
                                    </Button.Resources>
                                </Button>
                                <Button x:Name="RunCleaningButton" Click="OnRunCleaningClick" Content="运行清洗" UseSystemFocusVisuals="True" MinHeight="44" MinWidth="156">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8E1B1B" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FF8E1B1B" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FF6E1111" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FF6E1111" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF" />
                                    </Button.Resources>
                                </Button>
                                <Border BorderBrush="#33222222" BorderThickness="1" CornerRadius="10" Background="{StaticResource PanelAcrylicBrush}" Padding="10">
                                    <TextBlock x:Name="StatusTextBlock" Text="就绪" TextWrapping="Wrap" Foreground="#FF111111" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ResultsSectionGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource PanelAcrylicBrush}" CornerRadius="12" Padding="10">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FFC62828" CornerRadius="2" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="结果" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                            <TextBlock Text="产物、响应内容与运行诊断" Foreground="#FF4B5563" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto" HorizontalScrollMode="Disabled" Margin="0,10,0,0">
                    <Grid x:Name="ResultsCardsGrid" ColumnSpacing="14" RowSpacing="14">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition />
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="ResultsRow0" Height="Auto" />
                            <RowDefinition x:Name="ResultsRow1" Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ResultsCol0" Width="2*" />
                            <ColumnDefinition x:Name="ResultsCol1" Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ArtifactsCard" Grid.Column="0" Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="产物" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                    <Border Grid.Column="1" CornerRadius="999" Padding="10,4" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource PanelAcrylicBrush}">
                                        <TextBlock x:Name="ArtifactsCountTextBlock" Text="0 项" Foreground="#FF4B5563" />
                                    </Border>
                                </Grid>
                                <ListView x:Name="ArtifactsListView" Height="320" MinHeight="320" />
                                <TextBlock Text="原始响应" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                <TextBox x:Name="RawResponseTextBox" Height="220" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="RunResultCard" Grid.Column="1" Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="运行结果" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                    <Border x:Name="RunStatusBadgeBorder" Grid.Column="1" CornerRadius="999" Padding="10,4" BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource PanelAcrylicBrush}">
                                        <TextBlock x:Name="RunStatusBadgeText" Text="待运行" FontWeight="SemiBold" Foreground="#FF4B5563" />
                                    </Border>
                                </Grid>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="#33C62828" BorderThickness="1" CornerRadius="10" Padding="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFFF1F1" Offset="0" />
                                                <GradientStop Color="#FFFEE2E2" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="OK" Foreground="#FF374151" />
                                            <TextBlock x:Name="OkMetricTextBlock" Text="-" FontSize="18" FontWeight="SemiBold" Foreground="#FF111111" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" BorderBrush="#33C62828" BorderThickness="1" CornerRadius="10" Padding="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFFF1F1" Offset="0" />
                                                <GradientStop Color="#FFFEE2E2" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="模式" Foreground="#FF374151" />
                                            <TextBlock x:Name="ModeMetricTextBlock" Text="-" FontSize="18" FontWeight="SemiBold" Foreground="#FF111111" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" BorderBrush="#33C62828" BorderThickness="1" CornerRadius="10" Padding="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFFF1F1" Offset="0" />
                                                <GradientStop Color="#FFFEE2E2" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="耗时" Foreground="#FF374151" />
                                            <TextBlock x:Name="DurationMetricTextBlock" Text="-" FontSize="18" FontWeight="SemiBold" Foreground="#FF111111" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border BorderBrush="#33222222" BorderThickness="1" Background="{StaticResource PanelAcrylicBrush}" CornerRadius="10" Padding="10">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="作业 ID" FontWeight="SemiBold" Foreground="#FF374151" />
                                        <TextBlock x:Name="JobIdTextBlock" Text="-" TextWrapping="Wrap" />
                                        <TextBlock Text="摘要" FontWeight="SemiBold" Foreground="#FF374151" />
                                        <TextBlock x:Name="RunResultTextBlock" Text="-" TextWrapping="Wrap" />
                                        <TextBlock Text="运行模式" FontWeight="SemiBold" Foreground="#FF374151" />
                                        <TextBlock x:Name="RunModeTextBlock" Text="-" TextWrapping="Wrap" />
                                        <TextBlock Text="耗时（ms）" FontWeight="SemiBold" Foreground="#FF374151" />
                                        <TextBlock x:Name="DurationTextBlock" Text="-" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>

