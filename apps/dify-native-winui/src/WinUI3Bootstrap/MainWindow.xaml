                                           Foreground="#FF374151"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="GovernanceBoundaryRoutesTextBlock"
                                           AutomationProperties.AutomationId="GovernanceBoundaryRoutesTextBlock"
                                           Text="-"
                                           Foreground="#FF6B7280"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="GovernancePendingHintTextBlock" Text="使用当前 Bridge URL 查询后端审核队列。" Foreground="#FF4B5563" TextWrapping="Wrap" />
                                <ListView x:Name="PendingReviewsListView"
                                          AutomationProperties.AutomationId="PendingReviewsListView"
                                          Height="260"
                                          MinHeight="220"
                                          SelectionChanged="OnPendingReviewSelectionChanged" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="GovernanceDecisionCard" Grid.Row="1" Style="{StaticResource CardBorderStyle}">
