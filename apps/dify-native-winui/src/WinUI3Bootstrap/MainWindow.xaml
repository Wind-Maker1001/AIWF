                                <TextBlock Text="审核人" />
                                <TextBox x:Name="GovernanceReviewerTextBox" AutomationProperties.AutomationId="GovernanceReviewerTextBox" Style="{StaticResource TouchTextBoxStyle}" Text="native-reviewer" />
                                <TextBlock Text="备注" />
                                <TextBox x:Name="GovernanceCommentTextBox" AutomationProperties.AutomationId="GovernanceCommentTextBox" Style="{StaticResource TouchTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="88" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            x:Name="ApproveReviewButton"
                                            AutomationProperties.AutomationId="ApproveReviewButton"
                                            Click="OnApproveReviewClick"
                                            Content="批准"
                                            MinHeight="40"
                                            IsEnabled="False" />
                                    <Button Grid.Column="1"
                                            x:Name="RejectReviewButton"
                                            AutomationProperties.AutomationId="RejectReviewButton"
                                            Click="OnRejectReviewClick"
                                            Content="拒绝"
                                            MinHeight="40"
                                            IsEnabled="False" />
                                </Grid>
                                <TextBlock x:Name="GovernanceStatusTextBlock" AutomationProperties.AutomationId="GovernanceStatusTextBlock" Text="-" Foreground="#FF4B5563" TextWrapping="Wrap" />
                            </StackPanel>
