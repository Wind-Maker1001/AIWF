                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="QualityRuleSetIdTextBox"
                                             Grid.Column="0"
                                             AutomationProperties.AutomationId="QualityRuleSetIdTextBox"
                                             PlaceholderText="规则集 ID"
