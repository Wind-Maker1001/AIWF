                                            Click="OnSaveQualityRuleSetClick"
                                            Content="保存"
                                            MinHeight="36"
                                            Padding="14,0" />
                                </Grid>
                                <ListView x:Name="QualityRuleSetListView"
                                          AutomationProperties.AutomationId="QualityRuleSetListView"
                                          Height="180"
                                          MinHeight="160"
                                          SelectionChanged="OnQualityRuleSetSelectionChanged" />
                                <TextBox x:Name="QualityRuleSetJsonTextBox"
                                         AutomationProperties.AutomationId="QualityRuleSetJsonTextBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="180"
                                         Style="{StaticResource TouchTextBoxStyle}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="GovernanceSandboxCard" Grid.Row="5" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sandbox 治理" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                    <Button Grid.Column="1"
                                            x:Name="RefreshSandboxGovernanceButton"
                                            AutomationProperties.AutomationId="RefreshSandboxGovernanceButton"
                                            Click="OnRefreshSandboxGovernanceClick"
                                            Content="刷新"
                                            MinHeight="36"
                                            Padding="14,0" />
                                    <Button Grid.Column="2"
                                            x:Name="SaveSandboxRulesButton"
                                            AutomationProperties.AutomationId="SaveSandboxRulesButton"
                                            Click="OnSaveSandboxRulesClick"
                                            Content="保存"
                                            MinHeight="36"
                                            Padding="14,0"
                                            Margin="8,0,0,0" />
                                    <Button Grid.Column="3"
                                            x:Name="RollbackSandboxRuleVersionButton"
                                            AutomationProperties.AutomationId="RollbackSandboxRuleVersionButton"
                                            Click="OnRollbackSandboxRuleVersionClick"
                                            Content="回滚"
                                            MinHeight="36"
                                            Padding="14,0"
                                            Margin="8,0,0,0" />
                                </Grid>
                                <ListView x:Name="SandboxRuleVersionsListView"
                                          AutomationProperties.AutomationId="SandboxRuleVersionsListView"
                                          Height="180"
                                          MinHeight="160"
                                          SelectionChanged="OnSandboxRuleVersionSelectionChanged" />
                                <TextBox x:Name="SandboxRulesJsonTextBox"
                                         AutomationProperties.AutomationId="SandboxRulesJsonTextBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="180"
                                         Style="{StaticResource TouchTextBoxStyle}" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SandboxMuteNodeTypeTextBox"
                                             Grid.Column="0"
                                             AutomationProperties.AutomationId="SandboxMuteNodeTypeTextBox"
                                             PlaceholderText="mute node_type"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <TextBox x:Name="SandboxMuteNodeIdTextBox"
                                             Grid.Column="1"
                                             AutomationProperties.AutomationId="SandboxMuteNodeIdTextBox"
                                             PlaceholderText="mute node_id"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <TextBox x:Name="SandboxMuteCodeTextBox"
                                             Grid.Column="2"
                                             AutomationProperties.AutomationId="SandboxMuteCodeTextBox"
                                             PlaceholderText="mute code"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <TextBox x:Name="SandboxMuteMinutesTextBox"
                                             Grid.Column="3"
                                             AutomationProperties.AutomationId="SandboxMuteMinutesTextBox"
                                             PlaceholderText="分钟"
                                             Text="60"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <Button Grid.Column="4"
                                            x:Name="ApplySandboxMuteButton"
                                            AutomationProperties.AutomationId="ApplySandboxMuteButton"
                                            Click="OnApplySandboxMuteClick"
                                            Content="应用静默"
                                            MinHeight="36"
                                            Padding="14,0" />
                                </Grid>
                                <TextBlock Text="AutoFix 状态" FontWeight="SemiBold" Foreground="#FF374151" />
                                <TextBlock x:Name="SandboxAutoFixStateTextBlock"
                                           AutomationProperties.AutomationId="SandboxAutoFixStateTextBlock"
                                           Text="-"
                                           Foreground="#FF4B5563"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SandboxAutoFixModeTextBox"
                                             Grid.Column="0"
                                             AutomationProperties.AutomationId="SandboxAutoFixModeTextBox"
                                             PlaceholderText="forced isolation mode"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <TextBox x:Name="SandboxAutoFixUntilTextBox"
                                             Grid.Column="1"
                                             AutomationProperties.AutomationId="SandboxAutoFixUntilTextBox"
                                             PlaceholderText="forced until (ISO8601)"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <TextBox x:Name="SandboxAutoFixGreenStreakTextBox"
                                             Grid.Column="2"
                                             AutomationProperties.AutomationId="SandboxAutoFixGreenStreakTextBox"
                                             PlaceholderText="green streak"
                                             Text="0"
                                             Style="{StaticResource TouchTextBoxStyle}" />
                                    <Button Grid.Column="3"
                                            x:Name="SaveSandboxAutoFixStateButton"
                                            AutomationProperties.AutomationId="SaveSandboxAutoFixStateButton"
                                            Click="OnSaveSandboxAutoFixStateClick"
                                            Content="保存 AutoFix"
                                            MinHeight="36"
                                            Padding="14,0" />
                                    <Button Grid.Column="4"
                                            x:Name="ClearSandboxAutoFixOverrideButton"
                                            AutomationProperties.AutomationId="ClearSandboxAutoFixOverrideButton"
                                            Click="OnClearSandboxAutoFixOverrideClick"
                                            Content="清空 override"
                                            MinHeight="36"
                                            Padding="14,0" />
                                </Grid>
                                <TextBlock Text="AutoFix 历史" FontWeight="SemiBold" Foreground="#FF374151" />
                                <ListView x:Name="SandboxAutoFixActionsListView"
                                          AutomationProperties.AutomationId="SandboxAutoFixActionsListView"
                                          Height="160"
                                          MinHeight="140" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
