<Window
    x:Class="AIWF.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AIWF Native Desktop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8" Padding="12">
            <TextBlock Text="AIWF Native (WinUI 3 Bootstrap)" FontSize="16" FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1" Padding="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <NavigationView IsBackButtonVisible="Collapsed" IsSettingsVisible="False">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Run" />
                    <NavigationViewItem Content="Queue" />
                    <NavigationViewItem Content="Artifacts" />
                </NavigationView.MenuItems>
            </NavigationView>

            <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="8" BorderThickness="1">
                <TextBlock Margin="12" Text="Main content area (to be migrated from current Electron UI)." />
            </Border>
        </Grid>
    </Grid>
</Window>
