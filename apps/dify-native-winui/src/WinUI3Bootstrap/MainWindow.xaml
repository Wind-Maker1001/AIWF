<Window
    x:Class="AIWF.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AIWF Native Desktop">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="AIWF Native (WinUI 3 MVP)" FontSize="24" FontWeight="SemiBold" />
            <TextBlock
                Text="Run Config + Run Trigger + Artifact List (bridged via local HTTP)"
                Opacity="0.75" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Text="Bridge URL" />
                <TextBox x:Name="BridgeUrlTextBox" Text="http://127.0.0.1:18081" />
                <TextBlock Text="API Key (optional)" />
                <TextBox x:Name="ApiKeyTextBox" />
                <TextBlock Text="Owner" />
                <TextBox x:Name="OwnerTextBox" Text="native" />
                <TextBlock Text="Actor" />
                <TextBox x:Name="ActorTextBox" Text="native" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Report Title" />
                <TextBox x:Name="ReportTitleTextBox" Text="Native WinUI Smoke Report" />
                <TextBlock Text="Input CSV Path (optional)" />
                <TextBox x:Name="InputCsvTextBox" />
                <TextBlock Text="Office Theme" />
                <ComboBox x:Name="OfficeThemeComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="assignment" />
                    <ComboBoxItem Content="debate_plus" />
                    <ComboBoxItem Content="academic" />
                    <ComboBoxItem Content="professional" />
                </ComboBox>
                <TextBlock Text="Office Lang" />
                <ComboBox x:Name="OfficeLangComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="zh" />
                    <ComboBoxItem Content="en" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="10" VerticalAlignment="Bottom">
                <Button x:Name="HealthButton" Click="OnHealthClick" Content="Check Health" />
                <Button x:Name="RunCleaningButton" Click="OnRunCleaningClick" Content="Run Cleaning" />
                <TextBlock x:Name="StatusTextBlock" Text="Ready" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Text="Artifacts" FontSize="16" FontWeight="SemiBold" />
                <ListView x:Name="ArtifactsListView" Height="320" />
                <TextBlock Text="Raw Response" FontSize="16" FontWeight="SemiBold" />
                <TextBox
                    x:Name="RawResponseTextBox"
                    Height="220"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    IsReadOnly="True" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Run Result" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="RunResultTextBlock" Text="-" TextWrapping="Wrap" />
                <TextBlock Text="Run Mode" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="RunModeTextBlock" Text="-" TextWrapping="Wrap" />
                <TextBlock Text="Duration (ms)" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="DurationTextBlock" Text="-" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
