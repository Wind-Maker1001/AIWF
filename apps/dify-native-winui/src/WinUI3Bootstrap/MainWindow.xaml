                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="审核历史" FontSize="16" FontWeight="SemiBold" Foreground="#FF111111" />
                                    <Button Grid.Column="1"
                                            x:Name="RefreshReviewHistoryButton"
                                            AutomationProperties.AutomationId="RefreshReviewHistoryButton"
                                            Click="OnRefreshReviewHistoryClick"
                                            Content="刷新"
