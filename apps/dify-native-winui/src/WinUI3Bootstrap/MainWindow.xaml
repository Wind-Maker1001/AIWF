                                <ListView x:Name="GovernanceAuditLogListView"
                                          AutomationProperties.AutomationId="GovernanceAuditLogListView"
                                          Height="180"
                                          MinHeight="160" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="GovernanceQualityRuleCard" Grid.Row="4" Style="{StaticResource CardBorderStyle}">
