{
  "name": "aiwf-dify-desktop",
  "version": "1.1.6",
  "private": true,
  "author": "AIWF",
  "description": "AIWF Dify standalone desktop app",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "smoke": "node smoke.js",
    "test": "npm run test:unit",
    "test:regression": "node scripts/regression_baseline.js",
    "test:regression:dirty": "node scripts/regression_dirty.js",
    "test:office-gate": "node scripts/regression_office_gate.js",
    "acceptance:real": "node scripts/acceptance_real_samples.js",
    "test:unit": "node --test tests-node/*.test.js",
    "test:workflow-ui": "playwright test -c playwright.workflow.config.js",
    "test:build-e2e": "playwright test tests/build-e2e.spec.js -c playwright.workflow.config.js",
    "bench:routing": "node scripts/benchmark_routing.js",
    "build:win:dir": "electron-builder --win --dir",
    "build:win": "electron-builder --win portable",
    "build:win:installer": "electron-builder --win nsis",
    "build:win:installer:lite": "electron-builder --config build/electron-builder.lite.json --win nsis",
    "build:win:installer:release": "set AIWF_RELEASE=1&& electron-builder --win nsis",
    "build:win:release": "set AIWF_RELEASE=1&& electron-builder --win portable",
    "stress:chiplet-pool": "node scripts/stress_chiplet_pool.js",
    "stress:chiplet-pool:long": "set AIWF_CHIPLET_STRESS_SECONDS=1800&& set AIWF_CHIPLET_STRESS_CONCURRENCY=4&& node scripts/stress_chiplet_pool.js",
    "release:gate": "node scripts/release_gate_desktop.js",
    "release:verify-artifacts": "set AIWF_RELEASE_GATE_MODE=artifact_only&& node scripts/release_gate_desktop.js",
    "release:collect-desktop-artifacts": "node scripts/postbuild_collect_desktop.js",
    "build:win:release:gated": "set AIWF_SKIP_BUILD_ARTIFACT_CHECK=1&& npm run release:gate && npm run build:win:release && npm run release:collect-desktop-artifacts && set AIWF_SKIP_BUILD_ARTIFACT_CHECK=&& npm run release:verify-artifacts",
    "build:win:installer:release:gated": "set AIWF_SKIP_BUILD_ARTIFACT_CHECK=1&& npm run release:gate && npm run build:win:installer:release && npm run release:collect-desktop-artifacts && set AIWF_SKIP_BUILD_ARTIFACT_CHECK=&& npm run release:verify-artifacts",
    "release:oneclick": "node scripts/one_click_release.js"
  },
  "build": {
    "appId": "com.aiwf.difydesktop",
    "productName": "AIWF Dify Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main_config_support.js",
      "main_runtime_support.js",
      "main_runtime_encoding.js",
      "main_runtime_fonts.js",
      "main_runtime_tools.js",
      "main_runtime_bridge.js",
      "dify_adapter.js",
      "main_window_support.js",
      "workflow_engine.js",
      "workflow_graph.js",
      "workflow_utils.js",
      "workflow_services.js",
      "workflow_governance.js",
      "workflow_chiplets/registry.js",
      "workflow_chiplets/runner.js",
      "workflow_chiplets/executor.js",
      "workflow_chiplets/contract.js",
      "workflow_chiplets/external_loader.js",
      "workflow_chiplets/builtin_chiplets.js",
      "workflow_chiplets/isolated_worker_host.js",
      "workflow_chiplets/isolated_worker_process.js",
      "offline_engine.js",
      "offline_runtime.js",
      "offline_paper.js",
      "offline_outputs.js",
      "offline_ingest.js",
      "offline_ingest_parsers.js",
      "offline_text.js",
      "offline_worker.js",
      "main_ipc.js",
      "main_ipc_metrics.js",
      "main_ipc_workflow.js",
      "main_ipc_runtime.js",
      "preload.js",
      "renderer/**",
      "package.json",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "@fluentui/web-components": "^2.6.1",
    "docx": "^9.5.3",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.6.3",
    "image-size": "^2.0.2",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "uuid": "^13.0.0"
  }
}
