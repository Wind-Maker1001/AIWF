  "xlsx_rules": {
    "required_columns": ["account_no", "txn_date", "debit_amount", "credit_amount", "amount", "balance", "counterparty_name", "ref_no"],
    "header_confidence_min": 0.8,
    "sheet_row_count_min": 1,
    "cross_sheet_required_coverage_min": 1.0,
    "numeric_parse_rate_min": 0.95,
    "date_parse_rate_min": 0.95
  },
  "expected_row_fields": ["account_no", "txn_date", "debit_amount", "credit_amount", "amount", "balance", "counterparty_name", "ref_no"],
  "consistency_compare": true
}
