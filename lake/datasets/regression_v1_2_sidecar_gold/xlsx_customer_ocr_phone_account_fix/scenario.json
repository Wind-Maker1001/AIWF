{
  "id": "xlsx_customer_ocr_phone_account_fix",
  "input_files": [
    "input.xlsx"
  ],
  "canonical_profile": "customer_contact",
  "xlsx_all_sheets": true,
  "sheet_allowlist": [
    "Customers"
  ],
  "include_hidden_sheets": false,
  "quick_gate": true,
  "consistency_compare": true,
  "consistency_transform_compare": true,
  "consistency_rows_file": "consistency_rows.jsonl",
  "quality_rules": {
    "canonical_profile": "customer_contact",
    "required_fields": [
      "customer_name",
      "phone"
    ],
    "max_required_missing_ratio": 0.0,
    "unique_keys": [
      "phone"
    ],
    "duplicate_key_ratio_max": 0.0,
    "blank_row_ratio_max": 0.0
  },
  "xlsx_rules": {
    "required_columns": [
      "customer_name",
      "phone"
    ],
    "header_confidence_min": 0.8,
    "sheet_row_count_min": 1,
    "cross_sheet_required_coverage_min": 1.0
  },
  "expected_row_fields": [
    "customer_name",
    "phone",
    "city"
  ],
  "expected_recommended_profile": "customer_contact",
  "expected_recommended_template_id": "customer_contact_v1",
  "expected_candidate_profiles": [
    "customer_contact"
  ],
  "expected_header_mapping_fields": [
    "customer_name",
    "phone",
    "city"
  ],
  "rust_rules": {
    "platform_mode": "generic",
    "field_ops": [
      {
        "field": "phone",
        "op": "normalize_phone_cn"
      },
      {
        "field": "account_no",
        "op": "normalize_account_no"
      }
    ],
    "required_fields": [
      "customer_name",
      "phone",
      "account_no"
    ],
    "deduplicate_by": [
      "phone"
    ],
    "deduplicate_keep": "first"
  }
}
