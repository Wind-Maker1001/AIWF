{
  "id": "xlsx_finance_english_units",
  "input_files": [
    "input.xlsx"
  ],
  "canonical_profile": "finance_statement",
  "header_mapping_mode": "auto",
  "xlsx_all_sheets": true,
  "sheet_allowlist": [
    "Finance"
  ],
  "include_hidden_sheets": false,
  "quick_gate": true,
  "consistency_compare": true,
  "consistency_transform_compare": true,
  "consistency_rows_file": "consistency_rows.jsonl",
  "quality_rules": {
    "canonical_profile": "finance_statement",
    "required_fields": [
      "id",
      "amount"
    ],
    "unique_keys": [
      "id"
    ],
    "max_required_missing_ratio": 0.0,
    "duplicate_key_ratio_max": 0.0,
    "numeric_parse_rate_min": 1.0,
    "date_parse_rate_min": 0.0
  },
  "xlsx_rules": {
    "required_columns": [
      "id",
      "amount"
    ],
    "header_confidence_min": 0.8,
    "sheet_row_count_min": 1,
    "cross_sheet_required_coverage_min": 1.0,
    "numeric_parse_rate_min": 1.0,
    "date_parse_rate_min": 0.0
  },
  "expected_row_fields": [
    "id",
    "amount",
    "biz_date"
  ],
  "expected_recommended_profile": "finance_statement",
  "expected_recommended_template_id": "finance_report_v1",
  "expected_candidate_profiles": [
    "finance_statement"
  ],
  "expected_header_mapping_fields": [
    "id",
    "amount",
    "biz_date"
  ],
  "rust_rules": {
    "platform_mode": "generic",
    "casts": {
      "id": "int"
    },
    "required_fields": [
      "id",
      "amount"
    ],
    "deduplicate_by": [
      "id"
    ],
    "deduplicate_keep": "last",
    "field_ops": [
      {
        "field": "amount",
        "op": "parse_number"
      },
      {
        "field": "amount",
        "op": "scale_by_header_unit",
        "unit": "million"
      }
    ],
    "date_ops": [
      {
        "field": "biz_date",
        "op": "parse_ymd",
        "as": "biz_date"
      }
    ]
  }
}
