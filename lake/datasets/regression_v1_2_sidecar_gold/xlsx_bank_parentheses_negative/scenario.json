{
  "id": "xlsx_bank_parentheses_negative",
  "input_files": [
    "input.xlsx"
  ],
  "canonical_profile": "bank_statement",
  "xlsx_all_sheets": true,
  "sheet_allowlist": [
    "BankFlow"
  ],
  "include_hidden_sheets": false,
  "quick_gate": true,
  "consistency_compare": true,
  "consistency_transform_compare": true,
  "consistency_rows_file": "consistency_rows.jsonl",
  "quality_rules": {
    "canonical_profile": "bank_statement",
    "required_fields": [
      "account_no",
      "txn_date"
    ],
    "unique_keys": [
      "account_no",
      "txn_date",
      "ref_no",
      "amount"
    ],
    "max_required_missing_ratio": 0.0,
    "duplicate_key_ratio_max": 0.0,
    "numeric_parse_rate_min": 1.0,
    "date_parse_rate_min": 0.0
  },
  "xlsx_rules": {
    "required_columns": [
      "account_no",
      "txn_date",
      "amount",
      "balance",
      "counterparty_name",
      "ref_no"
    ],
    "header_confidence_min": 0.8,
    "sheet_row_count_min": 1,
    "cross_sheet_required_coverage_min": 1.0,
    "numeric_parse_rate_min": 1.0,
    "date_parse_rate_min": 0.0
  },
  "expected_row_fields": [
    "account_no",
    "txn_date",
    "amount",
    "balance",
    "counterparty_name",
    "ref_no"
  ],
  "expected_recommended_profile": "bank_statement",
  "expected_recommended_template_id": "bank_statement_v1",
  "expected_candidate_profiles": [
    "bank_statement"
  ],
  "expected_header_mapping_fields": [
    "account_no",
    "txn_date",
    "amount",
    "balance",
    "counterparty_name",
    "ref_no"
  ],
  "rust_rules": {
    "platform_mode": "generic",
    "field_ops": [
      {
        "field": "account_no",
        "op": "normalize_account_no"
      },
      {
        "field": "txn_date",
        "op": "parse_date"
      },
      {
        "field": "debit_amount",
        "op": "parse_number"
      },
      {
        "field": "credit_amount",
        "op": "parse_number"
      },
      {
        "field": "amount",
        "op": "parse_number"
      },
      {
        "field": "balance",
        "op": "parse_number"
      },
      {
        "field": "amount",
        "op": "sign_amount_from_debit_credit",
        "direction_field": "txn_type"
      }
    ],
    "required_fields": [
      "account_no",
      "txn_date",
      "amount",
      "balance",
      "ref_no"
    ],
    "deduplicate_by": [
      "account_no",
      "txn_date",
      "ref_no",
      "amount"
    ],
    "deduplicate_keep": "last"
  }
}
