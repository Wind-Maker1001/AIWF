    "source_ref_coverage": 0.5,
    "duplicate_claim_ratio": 0.0,
    "source_title_resolution_rate": 1.0,
    "citation_parse_success_rate": 1.0
  },
  "expected_raw_signal_summary": {
    "input_row_count": 4,
    "speaker_signal_rows": 2,
    "stance_signal_rows": 1,
    "source_ref_signal_rows": 2,
    "quote_signal_rows": 0,
    "ocr_noise_rows": 0
  },
  "expected_warnings": []
}
