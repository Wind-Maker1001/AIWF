    "source_ref_coverage": 0.0,
    "quote_only_ratio": 0.0,
    "duplicate_claim_ratio": 0.0
  },
  "expected_raw_signal_summary": {
    "input_row_count": 5,
    "speaker_signal_rows": 1,
    "stance_signal_rows": 1,
    "source_ref_signal_rows": 0,
    "quote_signal_rows": 0,
    "ocr_noise_rows": 0
  },
  "expected_warnings": ["source reference coverage is low for debate evidence rows"]
