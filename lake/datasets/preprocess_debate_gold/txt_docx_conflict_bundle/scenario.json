{
  "id": "txt_docx_conflict_bundle",
  "input_files": ["input.txt", "input.docx"],
  "preprocess_spec": {
    "output_format": "jsonl",
    "standardize_evidence": true,
    "generate_quality_report": true,
    "text_split_by_line": true,
    "detect_conflicts": true,
    "conflict_text_field": "claim_text"
  },
  "expected_row_fields": ["speaker", "argument_role", "stance", "debate_topic", "conflict_topic", "conflict_polarity", "conflict_flag", "source_type"],
  "expected_metrics": {
    "row_count": 3,
    "speaker_coverage": 1.0,
    "quote_only_ratio": 0.333333,
    "duplicate_claim_ratio": 0.0
  },
  "expected_raw_signal_summary": {
    "input_row_count": 3,
    "speaker_signal_rows": 3,
    "stance_signal_rows": 2,
    "source_ref_signal_rows": 0,
    "quote_signal_rows": 1,
    "ocr_noise_rows": 0
  },
  "expected_warnings": [
    "source reference coverage is low for debate evidence rows"
  ]
}
