{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiwf.local/contracts/desktop/node_config_validation_errors.schema.json",
  "title": "AIWF Node Config Validation Error Codes",
  "type": "object",
  "required": ["schema_version", "authority", "codes"],
  "properties": {
    "schema_version": {
      "const": "node_config_validation_errors.v1"
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "error_item_shape": {
      "type": "object",
      "required": ["path", "code", "message"],
      "properties": {
        "path": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "category", "description"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
