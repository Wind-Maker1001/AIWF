{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aiwf/contracts/desktop/template_pack_artifact.schema.json",
  "title": "AIWF Template Pack Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "source",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "const": "template_pack_artifact.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/templateEntry"
      }
    }
  },
  "definitions": {
    "templateEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "workflow_definition"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "template_spec_version": {
          "type": "integer",
          "minimum": 1
        },
        "workflow_definition": {
          "type": "object"
        },
        "params_schema": {
          "type": "object"
        },
        "governance": {
          "type": "object"
        },
        "runtime_defaults": {
          "type": "object"
        },
        "created_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
