{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aiwf/contracts/desktop/cleaning_template_registry.schema.json",
  "title": "AIWF Cleaning Template Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "const": "cleaning_template_registry.v1"
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "template_format": {
            "type": "string"
          },
          "params_schema": {
            "type": "object"
          },
          "cleaning_spec_v2": {
            "type": "object"
          },
          "rules": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
