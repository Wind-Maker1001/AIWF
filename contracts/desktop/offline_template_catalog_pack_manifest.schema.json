{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aiwf/contracts/desktop/offline_template_catalog_pack_manifest.schema.json",
  "title": "AIWF Offline Template Catalog Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version",
    "created_at",
    "files",
    "contract_schemas",
    "catalogs"
  ],
  "properties": {
    "schema_version": {
      "const": "offline_template_catalog_pack_manifest.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contract_schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "catalogs": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "generic_templates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
