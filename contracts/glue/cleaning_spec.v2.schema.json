    "schema": {
      "type": "object",
      "additionalProperties": true
    },
    "transform": {
      "type": "object",
      "additionalProperties": true
    },
    "quality": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
