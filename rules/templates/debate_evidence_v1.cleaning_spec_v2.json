{
  "schema_version": "cleaning_spec.v2",
  "ingest": {
    "external_enrichment_mode": "off",
    "document_parse_backend": "auto",
    "citation_parse_backend": "auto",
    "url_metadata_enrichment": true
  },
  "schema": {
    "canonical_profile": "debate_evidence",
    "defaults": {},
    "unique_keys": ["source_path", "speaker", "source_domain", "claim_text"],
    "header_aliases": {},
    "auto_normalize_headers": false,
    "header_normalizer": "none"
  },
  "transform": {
    "rename_map": {
      "ClaimText": "claim_text",
      "Claim": "claim_text",
      "Text": "claim_text",
      "Content": "claim_text",
      "Speaker": "speaker",
      "Speaker Name": "speaker",
      "SpeakerRole": "speaker_role",
      "ArgumentRole": "argument_role",
      "Stance": "stance",
      "SourceUrl": "source_url",
      "Source Title": "source_title",
      "SourceTitle": "source_title",
      "SourceDomain": "source_domain",
      "Citation": "citation_text",
      "Quote": "quote_text",
      "Topic": "debate_topic",
      "Language": "language",
      "PublishedAt": "published_at"
    },
    "casts": {
      "claim_text": "string",
      "speaker": "string",
      "speaker_role": "string",
      "argument_role": "string",
      "stance": "string",
      "source_url": "string",
      "source_title": "string",
      "source_domain": "string",
      "citation_text": "string",
      "quote_text": "string",
      "debate_topic": "string",
      "language": "string",
      "published_at": "string",
      "confidence": "float",
      "source_path": "string"
    },
    "required_fields": ["claim_text", "source_path"],
    "default_values": {},
    "include_fields": [],
    "exclude_fields": [],
    "filters": [
      { "op": "blank_row" },
      { "op": "header_repeat_row", "header_values": ["claim_text", "speaker", "stance", "source_url"], "min_matches": 2 }
    ],
    "deduplicate_by": ["source_path", "speaker", "source_domain", "claim_text"],
    "deduplicate_keep": "first",
    "survivorship": {
      "keys": ["source_path", "speaker", "source_domain", "claim_text"],
      "prefer_non_null_fields": ["source_url", "source_title", "citation_text", "quote_text"],
      "tie_breaker": "first"
    },
    "sort_by": [
      { "field": "source_path", "order": "asc" },
      { "field": "speaker", "order": "asc" }
    ],
    "aggregate": {},
    "null_values": [],
    "trim_strings": true,
    "computed_fields": {},
    "string_ops": [],
    "date_ops": [
      { "field": "published_at", "op": "parse_ymd" }
    ],
    "field_ops": []
  },
  "quality": {
    "required_fields": ["claim_text", "source_path"],
    "gates": {
      "max_required_missing_ratio": 0.0,
      "duplicate_key_ratio_max": 0.25,
      "allow_empty_output": false
    },
    "image_rules": {},
    "xlsx_rules": {}
  },
  "artifacts": {},
  "audit": {
    "enabled": true,
    "sample_limit": 5,
    "lineage": true,
    "warnings": []
  }
}
