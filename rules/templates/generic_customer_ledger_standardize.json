{
  "rules": {
    "platform_mode": "generic",
    "rename_map": {
      "CustomerName": "customer_name",
      "Name": "customer_name",
      "Customer": "customer_name",
      "客户名称": "customer_name",
      "姓名": "customer_name",
      "Phone": "phone",
      "Mobile": "phone",
      "Telephone": "phone",
      "手机": "phone",
      "手机号": "phone",
      "电话": "phone",
      "City": "city",
      "城市": "city",
      "Amount": "amount",
      "Amt": "amount",
      "金额": "amount",
      "Biz Date": "biz_date",
      "Biz Dt": "biz_date",
      "业务日期": "biz_date"
    },
    "casts": {
      "customer_name": "string",
      "phone": "string",
      "city": "string",
      "amount": "float",
      "biz_date": "string"
    },
    "trim_strings": true,
    "required_fields": ["customer_name", "phone", "amount", "biz_date"],
    "include_fields": ["customer_name", "phone", "city", "amount", "biz_date"],
    "filters": [
      { "field": "phone", "op": "regex", "value": "^[0-9+\\-\\s]{6,20}$" }
    ],
    "deduplicate_by": ["phone", "biz_date", "amount"],
    "deduplicate_keep": "first",
    "sort_by": [
      { "field": "biz_date", "order": "asc" },
      { "field": "customer_name", "order": "asc" }
    ]
  },
  "quality_rules": {
    "canonical_profile": "customer_ledger",
    "required_fields": ["customer_name", "phone", "amount", "biz_date"],
    "max_required_missing_ratio": 0.0,
    "numeric_parse_rate_min": 0.95,
    "date_parse_rate_min": 0.95,
    "allow_empty_output": false
  }
}
