{
  "schema_version": "cleaning_spec.v2",
  "ingest": {},
  "schema": {
    "canonical_profile": "bank_statement",
    "defaults": {
      "currency": "CNY"
    },
    "unique_keys": ["account_no", "txn_date", "ref_no", "amount"],
    "header_aliases": {},
    "auto_normalize_headers": false,
    "header_normalizer": "none"
  },
  "transform": {
    "rename_map": {
      "Acct No": "account_no",
      "Acct#": "account_no",
      "Acct_Num": "account_no",
      "Acct_No": "account_no",
      "账号": "account_no",
      "账户": "account_no",
      "账户号": "account_no",
      "卡号": "account_no",
      "Posting Dt": "txn_date",
      "Post Dt": "txn_date",
      "Posting Date": "txn_date",
      "交易日期": "txn_date",
      "记账日期": "txn_date",
      "入账日期": "txn_date",
      "日期": "txn_date",
      "DR": "debit_amount",
      "借方金额": "debit_amount",
      "支出": "debit_amount",
      "付款金额": "debit_amount",
      "CR": "credit_amount",
      "贷方金额": "credit_amount",
      "收入": "credit_amount",
      "收款金额": "credit_amount",
      "Bal": "balance",
      "余额": "balance",
      "账户余额": "balance",
      "Counterparty": "counterparty_name",
      "CP": "counterparty_name",
      "对方户名": "counterparty_name",
      "对手方": "counterparty_name",
      "交易对手": "counterparty_name",
      "Memo": "remark",
      "Remark": "remark",
      "摘要": "remark",
      "附言": "remark",
      "备注": "remark",
      "用途": "remark",
      "Ref No": "ref_no",
      "Reference No": "ref_no",
      "流水号": "ref_no",
      "交易流水号": "ref_no",
      "凭证号": "ref_no",
      "Txn Type": "txn_type",
      "Transaction Type": "txn_type",
      "交易类型": "txn_type",
      "业务类型": "txn_type",
      "方向": "txn_type",
      "Currency": "currency",
      "币种": "currency",
      "货币": "currency",
      "结算币种": "currency"
    },
    "casts": {
      "debit_amount": "float",
      "credit_amount": "float",
      "amount": "float",
      "balance": "float",
      "txn_date": "string",
      "account_no": "string",
      "counterparty_name": "string",
      "remark": "string",
      "ref_no": "string",
      "txn_type": "string",
      "currency": "string"
    },
    "required_fields": ["account_no", "txn_date"],
    "default_values": {
      "currency": "CNY"
    },
    "include_fields": [],
    "exclude_fields": [],
    "filters": [
      { "op": "blank_row" },
      { "op": "subtotal_row" },
      { "op": "note_row" },
      { "op": "header_repeat_row", "header_values": ["account_no", "txn_date", "debit_amount", "credit_amount", "balance"], "min_matches": 2 }
    ],
    "deduplicate_by": ["account_no", "txn_date", "ref_no", "amount"],
    "deduplicate_keep": "last",
    "survivorship": {
      "keys": ["account_no", "txn_date", "ref_no", "amount"],
      "prefer_non_null_fields": ["counterparty_name", "remark", "ref_no"],
      "prefer_latest_fields": ["txn_date"],
      "tie_breaker": "last"
    },
    "sort_by": [
      { "field": "txn_date", "order": "asc" },
      { "field": "ref_no", "order": "asc" }
    ],
    "aggregate": {},
    "null_values": [],
    "trim_strings": true,
    "computed_fields": {
      "amount": "sub($credit_amount,$debit_amount)"
    },
    "string_ops": [
      { "field": "currency", "op": "upper" }
    ],
    "date_ops": [
      { "field": "txn_date", "op": "parse_ymd" }
    ],
    "field_ops": [
      { "field": "account_no", "op": "normalize_account_no" },
      { "field": "counterparty_name", "op": "normalize_name" },
      { "field": "debit_amount", "op": "strip_currency_symbol" },
      { "field": "debit_amount", "op": "strip_thousands_sep" },
      { "field": "credit_amount", "op": "strip_currency_symbol" },
      { "field": "credit_amount", "op": "strip_thousands_sep" },
      { "field": "balance", "op": "strip_currency_symbol" },
      { "field": "balance", "op": "strip_thousands_sep" }
    ]
  },
  "quality": {
    "required_fields": ["account_no", "txn_date"],
    "gates": {
      "max_required_missing_ratio": 0.0,
      "duplicate_key_ratio_max": 0.1,
      "numeric_parse_rate_min": 0.95,
      "date_parse_rate_min": 0.95,
      "allow_empty_output": false
    },
    "advanced_rules": {
      "anomaly_iqr": [
        { "field": "amount", "max_ratio": 0.1 },
        { "field": "balance", "max_ratio": 0.1 }
      ],
      "block_on_advanced_rules": false
    },
    "image_rules": {},
    "xlsx_rules": {}
  },
  "artifacts": {},
  "audit": {
    "enabled": true,
    "sample_limit": 5,
    "lineage": true,
    "warnings": []
  }
}
